{
  "version": 2,
  "framework": null,
  "buildCommand": "pnpm build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "builds": [
    {
      "src": "dist/api.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/dist/api.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
